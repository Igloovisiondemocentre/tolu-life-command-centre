<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/task_card"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_card_medium"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="13dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/task_priority"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="HIGH // ACTIVE SIGNAL"
            android:textColor="#FFB31F"
            android:textSize="9sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/task_index"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="01 / 08"
            android:textColor="#8D99A8"
            android:textSize="9sp" />
    </LinearLayout>
    <TextView
        android:id="@+id/task_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="7dp"
        android:ellipsize="end"
        android:fontFamily="sans-serif-condensed"
        android:maxLines="2"
        android:text="CURRENT MISSION"
        android:textColor="#F5F4ED"
        android:textSize="21sp"
        android:textStyle="bold" />
    <TextView
        android:id="@+id/task_next"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="5dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="2"
        android:text="Next physical action"
        android:textColor="#AAB5C3"
        android:textSize="11sp" />
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/task_due"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="DUE TODAY"
            android:textColor="#8D99A8"
            android:textSize="9sp" />
        <TextView
            android:id="@+id/complete_task"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:background="@drawable/widget_complete"
            android:gravity="center"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            android:text="✓ COMPLETE"
            android:textColor="#071014"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
