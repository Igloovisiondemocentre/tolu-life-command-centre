<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_shell"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_shell"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-condensed"
            android:text="TOLU'S CC // LIVE MISSION"
            android:textColor="#F5F4ED"
            android:textSize="12sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/task_index"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_live"
            android:paddingLeft="8dp"
            android:paddingTop="4dp"
            android:paddingRight="8dp"
            android:paddingBottom="4dp"
            android:text="01 / 01"
            android:textColor="#B9F227"
            android:textSize="9sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/task_priority"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="13dp"
        android:text="SYSTEM READY // 60 SEC ROTATION"
        android:textColor="#B9F227"
        android:textSize="9sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/task_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="7dp"
        android:ellipsize="end"
        android:fontFamily="sans-serif-condensed"
        android:maxLines="2"
        android:text="OPEN TOLU'S CC TO LOAD MISSIONS"
        android:textColor="#F5F4ED"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/task_next"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="5dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="3"
        android:text="Your live task list synchronises when the app opens."
        android:textColor="#AAB5C3"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/task_due"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="9dp"
        android:text="NEXT ROTATION // 60 SECONDS"
        android:textColor="#8D99A8"
        android:textSize="9sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/open_app"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/widget_open"
            android:gravity="center"
            android:text="OPEN APP"
            android:textColor="#B9F227"
            android:textSize="10sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/next_task"
            android:layout_width="56dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="7dp"
            android:background="@drawable/widget_next"
            android:gravity="center"
            android:text="NEXT ›"
            android:textColor="#071014"
            android:textSize="9sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/complete_task"
            android:layout_width="88dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="7dp"
            android:background="@drawable/widget_complete"
            android:gravity="center"
            android:text="✓ COMPLETE"
            android:textColor="#071014"
            android:textSize="9sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
